# -------------------------------------------------
# R / RStudio
# -------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Rbuildignore

# -------------------------------------------------
# Git / Editor
# -------------------------------------------------
.gitignore.swp
.DS_Store
Thumbs.db

# -------------------------------------------------
# R CMD check / build artefacts
# -------------------------------------------------
*.tar.gz
*.Rcheck/
.Rcheck/
check/
inst/doc/

# -------------------------------------------------
# R Markdown / knitr
# -------------------------------------------------
README.html
README_files/
*.knit.md
*.utf8.md
*_cache/
*_files/
.cache/

# -------------------------------------------------
# Working directories
# -------------------------------------------------
deriv2Tests/wd/

# -------------------------------------------------
# Bench scratch outputs. Only the immutable pre_rewrite baseline lives
# in the repo; every other file under bench/baselines/ is transient.
# -------------------------------------------------
bench/baselines/*
!bench/baselines/focei_theoph_pre_rewrite.rds


# -------------------------------------------------
# Temporary / generated files
# -------------------------------------------------
.f*
*.log
*.tmp

# -------------------------------------------------
# Compiled objects
# -------------------------------------------------
*.o
*.so
*.dll
.positai

# -------------------------------------------------
# Stray codegen leftovers under tests/testthat/. Tests already
# setwd(tempdir()) before any cOde/CppODE call, so nothing should
# land here — these patterns guard against pre-rewrite paths slipping
# through and leaving artefacts behind. The only tracked non-.R files
# under tests/testthat/ are helper-*.R, setup.R, fixtures/, and _snaps/.
# -------------------------------------------------
tests/testthat/*.c
tests/testthat/*.cpp
tests/testthat/*.o
tests/testthat/*.so
tests/testthat/*.dll
tests/testthat/reactions_for_Alyssa*
# testthat auto-creates _snaps/ on every run, even when no test uses
# snapshots. If snapshot tests are added later, drop matching un-ignore
# rules here (e.g. !tests/testthat/_snaps/some-test/).
tests/testthat/_snaps/

# -------------------------------------------------
# Python caches (inst/code helpers shelled out via reticulate)
# -------------------------------------------------
__pycache__/
*.pyc

# -------------------------------------------------
# Claude stuff
# -------------------------------------------------
CLAUDE.md
/doc/
/Meta/
