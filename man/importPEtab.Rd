  outDir <- file.path(tempdir(), "petab_export")
  yamlOut <- exportPEtabObject(petab, outDir, formatVersion = "2.0.0",
                               overwrite = TRUE)
  petab2 <- importPEtab(yamlOut, solver = "deSolve")
