  ## v2 example (the bundled v2 test suite):
  yamlPath <- system.file("PEtabTests/v2/0001/_0001.yaml", package = "dMod")
  petab <- importPEtab(yamlPath, solver = "deSolve")

  ## v1 still works — same call, different YAML schema:
